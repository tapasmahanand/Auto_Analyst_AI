<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<title>{{ title }}</title>
<style>
  body { font-family: -apple-system, "Segoe UI", Helvetica, Arial, sans-serif;
         color: #1a202c; max-width: 860px; margin: 0 auto; padding: 2.5rem 1.5rem;
         line-height: 1.55; }
  h1 { font-size: 1.9rem; margin-bottom: .25rem; }
  h2 { font-size: 1.25rem; margin-top: 2.2rem; border-bottom: 2px solid #e2e8f0;
       padding-bottom: .35rem; }
  .meta { color: #64748b; font-size: .9rem; margin-bottom: 1.5rem; }
  .request { background: #f1f5f9; border-left: 4px solid #3b82f6; padding: .75rem 1rem;
             border-radius: 0 6px 6px 0; }
  table { border-collapse: collapse; width: 100%; font-size: .92rem; }
  td, th { border: 1px solid #e2e8f0; padding: .45rem .7rem; text-align: left; }
  th { background: #f8fafc; }
  .finding { background: #f8fafc; border: 1px solid #e2e8f0; border-radius: 8px;
             padding: .8rem 1rem; margin: .6rem 0; }
  .finding .numbers { color: #475569; font-size: .88rem; margin-top: .3rem; }
  .chart { margin: 1.2rem 0; text-align: center; page-break-inside: avoid; }
  .chart img { max-width: 100%; border: 1px solid #e2e8f0; border-radius: 8px; }
  .chart .caption { color: #64748b; font-size: .85rem; margin-top: .3rem; }
  ul { padding-left: 1.2rem; }
  .status { font-size: .8rem; color: #64748b; }
</style>
</head>
<body>
<h1>{{ title }}</h1>
<p class="meta">Generated by AutoAnalyst AI · {{ generated_at }}</p>
<p class="request"><strong>Analysis request:</strong> {{ prompt }}</p>

<h2>Executive Summary</h2>
<p>{{ executive_summary }}</p>

<h2>Dataset Overview</h2>
<table>
  <tr><th>File</th><td>{{ dataset.filename }} ({{ dataset.file_type | upper }})</td></tr>
  <tr><th>Rows × Columns</th><td>{{ dataset.row_count }} × {{ dataset.column_count }}</td></tr>
  <tr><th>Missing values</th><td>{{ dataset.total_missing_values }}</td></tr>
  <tr><th>Duplicate rows</th><td>{{ dataset.duplicate_rows }}</td></tr>
  {% if dataset.numeric_columns %}<tr><th>Numeric columns</th><td>{{ dataset.numeric_columns | join(', ') }}</td></tr>{% endif %}
  {% if dataset.categorical_columns %}<tr><th>Categorical columns</th><td>{{ dataset.categorical_columns | join(', ') }}</td></tr>{% endif %}
  {% if dataset.date_columns %}<tr><th>Date columns</th><td>{{ dataset.date_columns | join(', ') }}</td></tr>{% endif %}
</table>

<h2>Analysis Steps</h2>
<ol>
  {% for step in steps %}
  <li><strong>{{ step.goal }}</strong> — {{ step.method }}
      <span class="status">({{ step.status }}{% if step.attempts > 1 %}, {{ step.attempts }} attempts{% endif %})</span></li>
  {% endfor %}
</ol>

<h2>Key Findings</h2>
{% for f in key_findings %}
<div class="finding">
  <div>{{ f.finding }}</div>
  <div class="numbers">Supporting numbers: {{ f.supporting_numbers }}</div>
</div>
{% endfor %}

{% if charts %}
<h2>Charts</h2>
{% for chart in charts %}
<div class="chart">
  <img src="data:image/png;base64,{{ chart.b64 }}" alt="{{ chart.name }}">
  <div class="caption">{{ chart.name }}</div>
</div>
{% endfor %}
{% endif %}

<h2>Recommendations</h2>
<ul>
  {% for r in recommendations %}<li>{{ r }}</li>{% endfor %}
</ul>

<h2>Limitations</h2>
<ul>
  {% for l in limitations %}<li>{{ l }}</li>{% endfor %}
</ul>
</body>
</html>
