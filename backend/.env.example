# --- Required ---
# Your OpenAI API key. Never expose this to the frontend.
OPENAI_API_KEY=sk-...

# --- Optional (defaults shown) ---
# OpenAI model used for planning, code generation, review and insights.
OPENAI_MODEL=gpt-4o

# Max upload size for datasets, in megabytes.
MAX_UPLOAD_MB=50

# Wall-clock timeout for each AI-generated script execution, in seconds.
EXEC_TIMEOUT_SECONDS=60

# Memory cap for executed scripts, in megabytes.
EXEC_MEMORY_MB=2048

# How many times the AI may attempt to fix a failing script (total attempts = 1 + retries).
MAX_CODE_RETRIES=3

# Maximum number of steps in a generated analysis plan.
MAX_PLAN_STEPS=6

# Comma-separated list of allowed frontend origins.
CORS_ORIGINS=http://localhost:3000

# Directory for runtime data (uploads, runs, reports, SQLite DB).
# Defaults to <repo root>/storage. Point this at a mounted volume in production.
# STORAGE_DIR=/var/data/storage
